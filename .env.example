# Supabase project URL (from Settings > API)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (safe to expose in browser)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — used ONLY by scripts/seed.js, never in the browser
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Slack incoming webhook URL — used by the notify-slack Edge Function
# Create at: https://api.slack.com/apps > Your App > Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
